rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getUserCompanyId() {
      return getUserData().companyId;
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserCompanyId() == companyId;
    }

    function isSameSite(siteId) {
      return getUserData().siteId == siteId;
    }

    function isRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isAnyRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }

    function isAdmin() {
      return isRole('admin');
    }

    function isSupervisor() {
      return isRole('supervisor') || isRole('maintenance_supervisor');
    }

    function isPlantManager() {
      return isRole('plant_manager');
    }

    function isTechnician() {
      return isRole('technician');
    }

    function isStoreKeeper() {
      return isRole('store_keeper');
    }

    function isHrOfficer() {
      return isRole('hr_officer');
    }

    function canReadContractors() {
      return isAnyRole(['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin']);
    }

    function canManageContractors() {
      return isAnyRole(['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin']);
    }

    // ---------------------------------------------------------------------------
    // Users
    // ---------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAnyRole(['admin', 'maintenance_supervisor', 'plant_manager'])
      );
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Work Orders
    // ---------------------------------------------------------------------------

    match /workOrders/{woId} {

      function isAssignedTechnician() {
        return request.auth.uid in resource.data.assignedTechnicianIds;
      }

      function isWOSupervisor() {
        return request.auth.uid == resource.data.supervisorInChargeId;
      }

      function woSiteMatches() {
        return isSameSite(resource.data.siteId);
      }

      // Admin: full access
      allow read, write: if isAdmin();

      // Supervisor: full read/write for their site
      allow read, write: if isSupervisor() && woSiteMatches();

      // Plant Manager: read-only for their site
      allow read: if isPlantManager() && woSiteMatches();

      // Store Keeper: read-only for their site (to view CAD files + parts requests)
      allow read: if isStoreKeeper() && woSiteMatches();

      // Technician: read assigned WOs only
      allow read: if isTechnician() && woSiteMatches() && isAssignedTechnician();

      // Technician: update only allowed fields on assigned WOs
      allow update: if isTechnician()
        && woSiteMatches()
        && isAssignedTechnician()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'statusHistory',
          'actualStartTime', 'actualEndTime', 'totalDurationMinutes',
          'workDoneDescription', 'rootCause', 'rootCauseDescription',
          'partsUsed', 'technicianWorkLogs', 'contractorHoursLog',
          'postRepairChecklist', 'testRunResult', 'testRunNotes',
          'finalPhotos', 'machineStatusAfterRepair',
          'checklist', 'documents', 'updatedAt'
        ]);

      // Parts requests sub-collection
      match /partsRequests/{requestId} {
        // Technician (own WO), Supervisor, Plant Manager, Store Keeper, Admin can read
        allow read: if isAdmin()
          || (isSupervisor() && isSameSite(get(/databases/$(database)/documents/workOrders/$(woId)).data.siteId))
          || (isPlantManager() && isSameSite(get(/databases/$(database)/documents/workOrders/$(woId)).data.siteId))
          || (isStoreKeeper() && isSameSite(get(/databases/$(database)/documents/workOrders/$(woId)).data.siteId))
          || (isTechnician() && request.auth.uid in get(/databases/$(database)/documents/workOrders/$(woId)).data.assignedTechnicianIds);

        // Technician (own WO), Supervisor, Admin can create
        allow create: if isAdmin()
          || isSupervisor()
          || (isTechnician() && request.auth.uid in get(/databases/$(database)/documents/workOrders/$(woId)).data.assignedTechnicianIds);

        // Store Keeper can update status (approve/reject/issue)
        allow update: if isAdmin()
          || isStoreKeeper()
          || isSupervisor();

        allow delete: if isAdmin();
      }
    }

    // ---------------------------------------------------------------------------
    // WO Counters — Cloud Functions only
    // ---------------------------------------------------------------------------

    match /woCounters/{counterId} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------------------
    // Machine History — Cloud Functions write, authorised roles read
    // ---------------------------------------------------------------------------

    match /machineHistory/{machineId}/entries/{entryId} {
      allow read: if isAuthenticated() && isAnyRole([
        'maintenance_supervisor',
        'plant_manager',
        'technician',
        'store_keeper',
        'admin'
      ]);
      // All writes via Cloud Functions only
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // Breakdowns (Module 1 — existing)
    // ---------------------------------------------------------------------------

    // breakdown_tickets — used by dashboard widgets and Module 1 list/report pages
    match /breakdown_tickets/{ticketId} {
      allow read: if isAuthenticated() && isAnyRole([
        'floor_operator', 'technician', 'maintenance_supervisor', 'supervisor',
        'plant_manager', 'admin'
      ]);
      allow create: if isAuthenticated() && isAnyRole([
        'floor_operator', 'technician', 'maintenance_supervisor', 'supervisor',
        'plant_manager', 'admin'
      ]);
      allow update: if isAuthenticated() && isAnyRole([
        'technician', 'maintenance_supervisor', 'supervisor', 'plant_manager', 'admin'
      ]);
      allow delete: if isAdmin();
    }

    match /breakdowns/{breakdownId} {
      allow read: if isAuthenticated() && isAnyRole([
        'maintenance_supervisor', 'plant_manager', 'technician',
        'floor_operator', 'admin'
      ]);
      allow create: if isAuthenticated() && isAnyRole([
        'floor_operator', 'technician', 'maintenance_supervisor', 'plant_manager', 'admin'
      ]);
      allow update: if isAuthenticated() && isAnyRole([
        'technician', 'maintenance_supervisor', 'plant_manager', 'admin'
      ]);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // Machines (Module 3 stub — read access for WO creation)
    // ---------------------------------------------------------------------------

    match /machines/{machineId} {
      allow read: if isAuthenticated() && isAnyRole([
        'technician', 'maintenance_supervisor', 'plant_manager',
        'store_keeper', 'admin'
      ]);
      // Machines updated by Cloud Functions on WO sign-off; supervisors can update too
      allow write: if isAdmin() || isSupervisor() || isPlantManager();
    }

    // ---------------------------------------------------------------------------
    // Parts / Inventory (Module 6 stub — read for parts search in WO)
    // ---------------------------------------------------------------------------

    match /parts/{partId} {
      allow read: if isAuthenticated() && isAnyRole([
        'technician', 'maintenance_supervisor', 'plant_manager',
        'store_keeper', 'admin'
      ]);
      allow write: if isAdmin() || isStoreKeeper();
    }

    // ---------------------------------------------------------------------------
    // Contractors (Module 7) — external profiles only, no contractor logins
    // ---------------------------------------------------------------------------

    match /contractors/{contractorId} {
      function contractorCompanyMatches() {
        return belongsToCompany(resource.data.companyId);
      }

      function newContractorCompanyMatches() {
        return belongsToCompany(request.resource.data.companyId);
      }

      function financialKeys() {
        return [
          'paymentTerms', 'currency', 'standardLaborRate', 'overtimeRate',
          'emergencyCallOutFee', 'minimumCharge', 'travelFee', 'bankName',
          'bankBranch', 'bankAccountNumber', 'taxRegistrationNumber',
          'preferredInvoiceFormat'
        ];
      }

      allow read: if isAuthenticated() && contractorCompanyMatches()
        && (canReadContractors() || isHrOfficer());
      allow create: if isAuthenticated() && newContractorCompanyMatches()
        && canManageContractors()
        && request.resource.data.status in ['active', 'inactive'];
      allow update: if isAuthenticated() && contractorCompanyMatches()
        && newContractorCompanyMatches()
        && (
          isAdmin()
          || isPlantManager()
          || (
            isSupervisor()
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(financialKeys())
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'status', 'blacklistReason', 'blacklistedAt', 'blacklistedBy'
            ])
          )
        );
      allow delete: if isAdmin();

      match /documents/{documentId} {
        function docCompanyMatches() {
          return belongsToCompany(resource.data.companyId);
        }

        function newDocCompanyMatches() {
          return belongsToCompany(request.resource.data.companyId)
            && request.resource.data.contractorId == contractorId;
        }

        allow read: if isAuthenticated() && docCompanyMatches()
          && (canReadContractors() || isHrOfficer());
        allow create, update: if isAuthenticated() && newDocCompanyMatches()
          && canManageContractors();
        allow delete: if false;
      }

      match /technicians/{technicianId} {
        function techCompanyMatches() {
          return belongsToCompany(resource.data.companyId);
        }

        function newTechCompanyMatches() {
          return belongsToCompany(request.resource.data.companyId)
            && request.resource.data.contractorId == contractorId;
        }

        allow read: if isAuthenticated() && techCompanyMatches() && canReadContractors();
        allow create, update: if isAuthenticated() && newTechCompanyMatches() && canManageContractors();
        allow delete: if false;
      }
    }

    match /contractorJobs/{jobId} {
      function jobCompanyMatches() {
        return belongsToCompany(resource.data.companyId);
      }

      function newJobCompanyMatches() {
        return belongsToCompany(request.resource.data.companyId);
      }

      allow read: if isAuthenticated() && jobCompanyMatches()
        && isAnyRole(['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin']);
      allow create: if false;
      allow update: if isAuthenticated() && jobCompanyMatches()
        && newJobCompanyMatches()
        && (
          isAdmin()
          || isPlantManager()
          || (
            isSupervisor()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'invitationAcknowledgedAt', 'arrivedAt', 'arrivedLoggedBy',
              'workStartedAt', 'workCompletedAt', 'departedAt', 'onSiteDurationMinutes',
              'actualWorkDurationMinutes', 'workSteps', 'partsFromContractor',
              'totalPartsCost', 'checklistResults', 'testRunResult', 'testRunNotes',
              'machineStatusAfter', 'photoUrls', 'beforePhotoUrls', 'afterPhotoUrls',
              'documentUrls', 'signedOffBy', 'signedOffByName', 'signedOffAt',
              'signOffNotes', 'signOffSignature', 'isDisputed', 'disputeNotes',
              'rating', 'followUpRequired', 'followUpReason', 'followUpBreakdownId',
              'contractorInvoiceAmount', 'contractorInvoiceRef', 'contractorInvoiceDate',
              'contractorInvoiceUrl', 'invoiceStatus', 'updatedAt'
            ])
          )
          || (
            isStoreKeeper()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'partsFromFactory', 'totalPartsFactoryCost', 'totalPartsCost', 'updatedAt'
            ])
          )
        );
      allow delete: if false;
    }

    match /contractorInvitations/{invitationId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && isAnyRole(['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin']);
      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------------------
    // Users (FCM tokens, roles, site assignments)
    // ---------------------------------------------------------------------------

    match /siteConfig/{siteId} {
      allow read: if isAuthenticated() && isSameSite(siteId);
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // Triage Flows (Module 4)
    // ---------------------------------------------------------------------------

    match /triageFlows/{flowId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
                   && isAnyRole(['supervisor', 'plant_manager', 'admin']);
      allow write: if isAuthenticated() && isAnyRole(['supervisor', 'admin'])
                   && request.resource.data.companyId == getUserCompanyId();
    }

    // ---------------------------------------------------------------------------
    // Triage Sessions (Module 4)
    // ---------------------------------------------------------------------------

    match /triageSessions/{sessionId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
                   && isAnyRole(['supervisor', 'plant_manager', 'admin', 'technician']);
      allow write: if isAuthenticated() && isAnyRole(['supervisor', 'admin'])
                   && request.resource.data.companyId == getUserCompanyId();
    }

    // ---------------------------------------------------------------------------
    // Triage Templates (Module 4 — read-only for customers)
    // ---------------------------------------------------------------------------

    match /triageTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ---------------------------------------------------------------------------
    // Companies & company users — required for signup / login / profile load
    // ---------------------------------------------------------------------------

    // /companies/{companyId}
    // - Creating the company on signup: allowed when the authenticated user
    //   is being recorded as the admin of the new company.
    // - Reading / updating: members of that company.
    match /companies/{companyId} {
      allow read: if isAuthenticated()
        && (
          // Owner / member lookup via /users/{uid} mapping
          (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && getUserData().companyId == companyId)
          // Or the company document itself records this user as admin (used
          // during signup before /users/{uid} mapping is readable in rules).
          || (resource != null && resource.data.adminUserId == request.auth.uid)
        );

      allow create: if isAuthenticated()
        && request.resource.data.adminUserId == request.auth.uid
        && request.resource.data.id == companyId;

      allow update: if isAuthenticated()
        && (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && getUserData().companyId == companyId
            && getUserData().role == 'admin')
          || resource.data.adminUserId == request.auth.uid
        );

      allow delete: if false;
    }

    // /companies/{companyId}/users/{userId} — per-company user profile
    match /companies/{companyId}/users/{userId} {
      allow read: if isAuthenticated()
        && (
          request.auth.uid == userId
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && getUserData().companyId == companyId
              && getUserData().role in ['admin', 'maintenance_supervisor', 'plant_manager', 'hr_officer', 'supervisor'])
        );

      // Self-create during signup; admins can create afterwards
      allow create: if isAuthenticated()
        && (
          request.auth.uid == userId
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && getUserData().companyId == companyId
              && getUserData().role == 'admin')
        );

      // Self-update (e.g. lastLoginAt, profile fields) or admin-update
      allow update: if isAuthenticated()
        && (
          request.auth.uid == userId
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && getUserData().companyId == companyId
              && getUserData().role in ['admin', 'supervisor'])
        );

      allow delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().companyId == companyId
        && getUserData().role == 'admin';
    }

    // /departments/{deptId} — company department list, managed by admin/supervisor
    match /departments/{deptId} {
      allow read: if isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().companyId == resource.data.companyId;
      allow create: if isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().companyId == request.resource.data.companyId
        && getUserData().role in ['admin', 'supervisor', 'plant_manager'];
      allow update, delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().companyId == resource.data.companyId
        && getUserData().role in ['admin', 'supervisor'];
    }

    // /companies/{companyId}/pendingInvites/{token} — saved during onboarding,
    // consumed by a Cloud Function or admin later.
    match /companies/{companyId}/pendingInvites/{token} {
      allow read, write: if isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().companyId == companyId
        && getUserData().role in ['admin', 'maintenance_supervisor', 'plant_manager', 'hr_officer'];
    }

    // ---------------------------------------------------------------------------
    // Inventory Module (Module 6 — full implementation)
    // ---------------------------------------------------------------------------

    match /companies/{companyId}/inventoryParts/{partId} {
      // Everyone authenticated in the company can read
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      // Create: store_keeper, supervisor, plant_manager, admin
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      // Update: store_keeper, supervisor, plant_manager, admin
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      // Delete: plant_manager and admin only (never technician or store_keeper)
      allow delete: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['plant_manager', 'admin'];
    }

    // stockMovements — IMMUTABLE audit log — never allow delete or update
    match /companies/{companyId}/stockMovements/{movementId} {
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      allow update: if false;  // Immutable
      allow delete: if false;  // NEVER delete stock movements
    }

    // partsRequests — top-level inventory parts requests (distinct from WO sub-collection)
    match /companies/{companyId}/partsRequests/{requestId} {
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      // Create: any authenticated user in the company
      allow create: if isAuthenticated() && getUserData().companyId == companyId;
      // Update: store_keeper, supervisor, plant_manager, admin can review/approve
      // Technician can only cancel their own requests
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && (getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin']
          || (getUserData().role == 'technician' && resource.data.requestedBy == request.auth.uid
              && request.resource.data.status == 'cancelled'));
      allow delete: if false;
    }

    // purchaseOrders
    match /companies/{companyId}/purchaseOrders/{poId} {
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      allow delete: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['plant_manager', 'admin'];
    }

    // inventoryImportSessions
    match /companies/{companyId}/inventoryImportSessions/{sessionId} {
      allow read: if isAuthenticated() && getUserData().companyId == companyId
        && (getUserData().role in ['maintenance_supervisor', 'plant_manager', 'admin']
          || resource.data.importedBy == request.auth.uid);
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['store_keeper', 'maintenance_supervisor', 'plant_manager', 'admin'];
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && (getUserData().role in ['maintenance_supervisor', 'plant_manager', 'admin']
          || resource.data.importedBy == request.auth.uid);
      allow delete: if false;
    }

    // inventorySettings — one doc per company
    match /companies/{companyId}/inventorySettings/{settingsId} {
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      allow write: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['maintenance_supervisor', 'plant_manager', 'admin'];
    }

    // ---------------------------------------------------------------------------
    // Training Module 5 — Training System
    // ---------------------------------------------------------------------------

    // trainingModules — authored content, company-scoped
    match /companies/{companyId}/trainingModules/{moduleId} {
      // Read: all staff roles + trainee + floor_operator (trainees need to load module content)
      allow read: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in [
          'trainee', 'floor_operator', 'supervisor', 'plant_manager',
          'hr_officer', 'admin'
        ];
      // Create / Update: supervisor and admin
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['supervisor', 'admin'];
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['supervisor', 'admin'];
      // Delete: admin only
      allow delete: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role == 'admin';
    }

    // trainingAssignments — individual learner enrolments, company-scoped
    match /companies/{companyId}/trainingAssignments/{assignmentId} {
      // Read: own assignment (trainee/floor_operator) OR management roles
      allow read: if isAuthenticated() && getUserData().companyId == companyId
        && (
          resource.data.traineeId == request.auth.uid
          || getUserData().role in ['supervisor', 'plant_manager', 'hr_officer', 'admin']
        );
      // Create: supervisor and admin
      allow create: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['supervisor', 'admin'];
      // Update: trainee can only update their own progress fields; supervisors/admins can update anything
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && (
          (
            resource.data.traineeId == request.auth.uid
            && getUserData().role in ['trainee', 'floor_operator']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'lessonProgress', 'quizAttempts', 'lastActivityAt',
              'overallProgress', 'lessonsCompleted', 'startedAt',
              'bestScore', 'latestScore', 'quizPassed', 'quizPassedAt',
              'attemptsUsed', 'status'
            ])
          )
          || getUserData().role in ['supervisor', 'admin']
        );
      // Delete: admin only
      allow delete: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role == 'admin';
    }

    // trainingCertificates — immutable audit record, company-scoped
    match /companies/{companyId}/trainingCertificates/{certificateId} {
      // Read: own certificate OR management roles
      allow read: if isAuthenticated() && getUserData().companyId == companyId
        && (
          resource.data.traineeId == request.auth.uid
          || getUserData().role in ['supervisor', 'plant_manager', 'hr_officer', 'admin']
        );
      // Create: via Cloud Function only — direct client writes disabled
      allow create: if false;
      // Update: admin or plant_manager (e.g. for revocation)
      allow update: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['plant_manager', 'admin'];
      // Delete: never
      allow delete: if false;
    }

    // trainingContentLibrary — shared media assets, company-scoped
    match /companies/{companyId}/trainingContentLibrary/{itemId} {
      // Read: supervisor, plant_manager, admin
      allow read: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['supervisor', 'plant_manager', 'admin'];
      // Write (create/update/delete): supervisor and admin
      allow write: if isAuthenticated() && getUserData().companyId == companyId
        && getUserData().role in ['supervisor', 'admin'];
    // pm_schedules — Preventive Maintenance Schedules
    }

    // shift_config — admin-managed shift setup
    match /shift_config/{configId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin', 'hr_officer'];
      allow create: if isAuthenticated() && belongsToCompany(request.resource.data.companyId)
        && isAdmin();
      allow update, delete: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && isAdmin();
    }

    // shift_handovers — supervisor accountability transfer records
    match /shift_handovers/{handoverId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin', 'hr_officer'];
      allow create: if isAuthenticated() && belongsToCompany(request.resource.data.companyId)
        && getUserData().role in ['supervisor', 'maintenance_supervisor', 'admin'];
      allow update: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'maintenance_supervisor', 'admin'];
      allow delete: if false;
    }

    // shift_stats — analytics feed written by Cloud Functions
    match /shift_stats/{statId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'maintenance_supervisor', 'plant_manager', 'admin'];
      allow write: if false;
    }

    match /pm_schedules/{scheduleId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'plant_manager', 'admin', 'technician'];
      allow create: if isAuthenticated()
        && getUserData().role in ['supervisor', 'admin'];
      allow update: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'admin'];
      allow delete: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'admin'];
    }

    // pm_history — PM execution history
    match /pm_history/{historyId} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'plant_manager', 'admin', 'technician'];
      allow create: if isAuthenticated(); // System-generated
      allow update: if isAuthenticated() && belongsToCompany(resource.data.companyId)
        && getUserData().role in ['supervisor', 'admin'];
      allow delete: if false;
    }
  }
}
